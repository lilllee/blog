# Copy this file to .env and fill in values.
#   cp .env.example .env
#
# In dev/test, runtime.exs auto-loads this file.
# In prod, set these as real environment variables.

# --- Admin (required for /admin/*) ---
BLOG_ADMIN_USER=admin
BLOG_ADMIN_PASS=change-me

# --- Translation (optional; enables ko↔en/ja/zh on the public site) ---
# GEMINI_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-2.0-flash

# --- Prod-only ---
# Generate with: mix phx.gen.secret
# SECRET_KEY_BASE=
# PHX_HOST=blog.example.com
# PORT=4000
# DATABASE_PATH=/data/prod.db
# POOL_SIZE=10
